# CAT_ADMIN_DEFAULT_PASSWORD=admin123

# Protect endpoints with an access token
# CAT_API_KEY=meow

# self reload during development
# CAT_DEBUG=true

# Log levels
# CAT_LOG_LEVEL=INFO

# CORS
# CAT_CORS_ENABLED=true
# CAT_CORS_ALLOWED_ORIGINS=https://example.org,https://www.example.org
# Comma separated list of IPs to trust with proxy headers. A wildcard '*' means always trust.
# CAT_CORS_FORWARDED_ALLOW_IPS="*"

# Redis server
# CAT_REDIS_HOST=<host>
# CAT_REDIS_PORT=6379
# CAT_REDIS_DB=<optional_db>
# CAT_REDIS_PASSWORD=<optional_password>
# CAT_REDIS_TLS=true

# JWT (JSON Web Token) settings: secret key and expiration time in minutes
# CAT_JWT_SECRET=<your_jwt_secret>
# CAT_JWT_EXPIRE_MINUTES=60

# Uvicorn and FastAPI operating behind https proxy
# CAT_HTTPS_PROXY_MODE=true

# Set the expiration time for the history conversation in the Redis storage
# CAT_HISTORY_EXPIRATION=30

# Set the values to encrypt / decrypt privacy data
# CAT_CRYPTO_KEY=<your_cryptography_key>
# CAT_CRYPTO_SALT=<your_cryptography_salt>